{
    "manifest_version": 3,
    "name": "Price rounder",
    "version": "1.1.0",

    "browser_specific_settings": {
        "gecko": {
            "id": "price-rounder@azom.dev"
        }
    },

    "description": "Round up psychological pricing to its nearest whole value, revealing the true cost of items on selected websites. Supports a wide range of currencies, including € $ £ ¥ ₹ ₩ ₽ ₺ ₪ ₦ ৳ ₱ ₨.",

    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "css": ["content_script.css"],
            "js": ["shared/storage.js", "content_script.js"]
        }
    ],

    "icons": {
        "48": "icon.png"
    },

    "action": {
        "default_icon": "icon.png",
        "default_title": "Price Rounder",
        "default_popup": "popup/popup.html"
    },

    "options_ui": {
        "page": "options/options.html"
    },

    "permissions": ["activeTab", "storage"]
}
